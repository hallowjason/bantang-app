# ─── Frontend (Vite) ──────────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Google Sheets 課表整合（課表 Sheet 的 ID，來自網址中的那一段）
VITE_SHEET_ID=

# Backend API URL（production 指向 Zeabur；dev 預設 http://localhost:3000）
VITE_API_URL=

# ─── Server (server/.env) ─────────────────────────────────────────────────────
# MongoDB 連線字串（必填）
MONGODB_URI=

# Firebase Admin 憑證：擇一設定（必填）
# B64：把 service account JSON 檔 base64 後貼進來（推薦，避免換行問題）
FIREBASE_SERVICE_ACCOUNT_B64=
# 或直接貼 JSON 字串
FIREBASE_SERVICE_ACCOUNT_JSON=

# 前端來源（CORS 白名單）
FRONTEND_URL=http://localhost:5173

# 伺服器 port（Zeabur 建議 8080；zbpack.json 已設）
PORT=8080

# 上傳檔案存放目錄（預設 cwd/uploads；Zeabur 需掛 volume 持久化）
UPLOADS_DIR=
